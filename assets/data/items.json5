{
  // 这里定义了一些没有特殊词条，属性固定的物品

  // type 决定了物品在物品栏中的大类，
  // consumable 可消耗的物品，使用后会消失
  // equipment 可装备的物品，装备后会提供属性加成
  // craftmaterial 用于打造的材料，不能直接使用
  // miscellaneous 其他类型的物品，可能有特殊用途

  // 特殊属性：
  // isRankedName 该物品根据境界不同而有独特的名字
  // isRankedItem 该物品境界和稀有度至少为1，属性应用于从 1 到 5 的不同境界，并且会拥有相应的 flavortext 和 icon
  // isIdentified 是否已鉴定
  // isUntradable 是否不可交易
  // isUnstackable 是否不可堆叠
  // isUsable 是否可使用
  // isCombinable 是否可合成，通常是用碎片组合成完整物品
  // isEquipable 是否可装备
  // isCursed 是否被诅咒，诅咒的物品装备后不能卸下
  // isCorrupted 是否被腐化，腐化的物品不能通过打造来修改属性
  // isAfflicted 是否被污染，污染的物品主词条是负面属性

  // 除非特别设定，否则 prototype 物品的 kind == id
  exp_pack: {
    id: "exp_pack",
    name: "exp_pack",
    flavortext: "flavortext_exp_pack",
    type: "consumable",
    category: "exp_pack",
    rarity: "rare",
    icon: "item/exp_pack.png",
    isIdentified: true,
    isUntradable: true,
  },
  identify_scroll: {
    id: "identify_scroll",
    name: "identify_scroll",
    flavortext: "flavortext_identify_scroll",
    type: "consumable",
    category: "identify_scroll",
    rarity: "rare",
    icon: "item/unique_scroll.png",
    isUsable: true,
    isIdentified: true,
  },

